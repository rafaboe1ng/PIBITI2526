<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/athon.leite/ontologies/2015/10/untitled-ontology-41#"
     xml:base="http://www.semanticweb.org/athon.leite/ontologies/2015/10/untitled-ontology-41"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:MaterialsOntology="http://www.semanticweb.org/athon.leite/ontologies/2015/10/MaterialsOntology#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:Material_Core="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core">
        <rdfs:comment>Ontology that associates materials with their respective properties</rdfs:comment>
    </owl:Ontology>
    


