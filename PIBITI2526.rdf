                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isFeatureOf"/>
                                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#f"/>
