                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#m"/>
                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#rmin"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
