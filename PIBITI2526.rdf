<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#"
     xml:base="http://www.semanticweb.org/rafab/ontologies/PIBITI2526"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526">
        <owl:imports rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core"/>
        <rdfs:comment xml:lang="en">Specialized Application Ontology (SAO) for sheet metal aerospace parts. Imports the Manufacturing Core (process/resource vocabulary) and the Material Core (material properties). Models domain-specific concepts: Sheet_Metal_Part (subClassOf mfg:Product), Product_Feature taxonomy (Hole, Flange, Web, Corner, Boss, Chamfer, Slot, Thread).</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#canProcessFeature -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#canProcessFeature">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isProcessedBy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Machine"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:comment xml:lang="en">Inferred: links a Machine to a Product_Feature it is capable of processing, given its capacity constraints and the feature geometry.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasChildFeature -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasChildFeature">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasParentFeature"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFeature -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFeature">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isFeatureOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasManufacturingPlan -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasManufacturingPlan">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Manufacturing_Process"/>
        <rdfs:comment xml:lang="en">Links a Sheet_Metal_Part to a Manufacturing_Process that is part of its overall production route (e.g., Blanking, Bending, Painting). Operates at the part level, complementing mfg:requiresProcess which operates at the Product_Feature level. Not functional: a part typically requires several processes.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasMaterial -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasMaterial">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isMaterialOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Material_Core"/>
        <rdfs:comment xml:lang="en">Links a Sheet_Metal_Part to its constituent material (instance of mc:Material_Core or any subclass). Functional: each part has at most one material.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasParentFeature -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasParentFeature">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasProcess -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasProcess">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Manufacturing_Process"/>
        <rdfs:comment xml:lang="en">Links a Sheet_Metal_Part to each Manufacturing_Process required to produce it. Inferred by SWRL from canProcessFeature assertions. Multiple values expected — one per process type needed by the part.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isFeatureOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isFeatureOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isMaterialOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isMaterialOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Material_Core"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isProcessedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#isProcessedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Machine"/>
        <rdfs:comment xml:lang="en">Inverse of canProcessFeature. Links a Product_Feature to the Machine(s) capable of processing it. Inferred by Pellet from canProcessFeature assertions and SWRL rules — never populated manually.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#precedesProcess -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#precedesProcess">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Manufacturing_Process"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Manufacturing_Process"/>
        <rdfs:comment xml:lang="en">Asserts that one manufacturing process must be completed before another begins. Domain and range: mfg:Manufacturing_Process. Static domain knowledge — not inferred.</rdfs:comment>
        <rdfs:label xml:lang="en">precedesProcess</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess -->

    <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasBendCondition -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasBendCondition">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Bend timing/condition classifier. Expected values: Immediate, Delayed.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasBendCount -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasBendCount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Number-of-bends classifier. Expected values: Single, Multiple.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasBendDirection -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasBendDirection">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Bend direction relative to the web. Expected values: Up, Down.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasBendRadius -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasBendRadius">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasCanonicalLabel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasCanonicalLabel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Normalized feature type label produced by class_for_label(). Coexists with rawFeatureLabel: rawFeatureLabel keeps the verbatim source string, hasCanonicalLabel keeps the normalized form used to determine the feature class.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasDiameter -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasDiameter">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Hole"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFeatureCount -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFeatureCount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Total feature count declared in the source JSON. Useful to validate parser coverage against TXT extraction.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFlangeAngleType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFlangeAngleType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Flange angle relative to the web. Expected values: Perpendicular, Acute, Obtuse.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFlangeProfile -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFlangeProfile">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Flange profile geometry. Expected values: Planar, Curved.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasID -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasID">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasLength -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasLength">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasMaterialLabel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasMaterialLabel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Raw material identifier as read from source files, before resolution to a Material_Core instance.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasMinBendRadiusCoefficient -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasMinBendRadiusCoefficient">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Aluminum"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Minimum bend radius expressed as a multiple of sheet thickness (r_min = coeff * t). ESTIMATED: AL7075 coeff=2.0 (conservative for O-temper; T6 would require 3-4).</rdfs:comment>
        <rdfs:label xml:lang="en">hasMinBendRadiusCoefficient</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasParentID -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasParentID">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPartName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPartName">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionNormalX -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionNormalX">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionNormalY -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionNormalY">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionNormalZ -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionNormalZ">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionPointX -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionPointX">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionPointY -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionPointY">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionPointZ -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasPositionPointZ">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasRadius -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasRadius">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Corner"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasSourceFile -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasSourceFile">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Path or filename of the TXT/JSON source from which this part was extracted. Used for AFR pipeline traceability.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasThickness -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasThickness">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">DEPRECATED. Composite raw flange type string from the source TXT. Kept for traceability only. New consumers should read hasBendDirection, hasBendCount, hasBendCondition, hasFlangeProfile, hasFlangeAngleType.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasWidth -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasWidth">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#laserPower -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#laserPower">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#LaserCutter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Rated laser power (W). Informational — determines cutting speed per thickness.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxBedSizeX -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxBedSizeX">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#HydroformPress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Dimensão X máxima do leito da hidroformadora (mm).</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxBedSizeY -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxBedSizeY">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#HydroformPress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Dimensão Y máxima do leito da hidroformadora (mm).</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxDrillDiameter -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxDrillDiameter">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#DrillPress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Diâmetro máximo de broca disponível (mm).</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxDrillThickness -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxDrillThickness">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#DrillPress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Maximum sheet thickness the drill press can drill through (mm). ESTIMATED: 150mm for DrillPress_01 (industrial column drill press).</rdfs:comment>
        <rdfs:label xml:lang="en">maxDrillThickness</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxHydroformThickness -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxHydroformThickness">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#HydroformPress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Maximum sheet thickness the hydroform press can form (mm). Hydroforming is limited to thin sheets; beyond this the material cannot be drawn.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxLaserSheetThickness -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxLaserSheetThickness">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#LaserCutter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Maximum sheet thickness the laser can cut through at full power (mm). Beyond this limit the cut quality degrades and the machine cannot complete the profile.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxPunchDiameter -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxPunchDiameter">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#PunchPress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Diâmetro máximo de punção (mm). Furos com diâmetro maior não podem ser puncionados.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxSheetLength -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxSheetLength">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#PressBreake"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Comprimento máximo de chapa que cabe na dobradeira (mm).</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxSheetThickness -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxSheetThickness">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Espessura máxima de chapa processável (mm). Aplica-se a PunchPress e PressBreake.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#minCutRadius -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#minCutRadius">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#LaserCutter"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="en">Minimum internal corner radius achievable by the laser (mm). Determined by the laser kerf width and beam focus diameter.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#minDrillDiameter -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#minDrillDiameter">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#DrillPress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Diâmetro mínimo de broca disponível (mm).</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#minFlangeWidth -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#minFlangeWidth">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#PressBreake"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Largura mínima de flange que a dobradeira consegue dobrar (mm). Determinado pela abertura da matriz.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#minPunchDiameter -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#minPunchDiameter">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#PunchPress"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment xml:lang="pt">Diâmetro mínimo de punção (mm). Limite estrutural ≈ 1× espessura da chapa.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#rawFeatureLabel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#rawFeatureLabel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


