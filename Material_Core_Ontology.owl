    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polipropylene -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polipropylene">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermoplastics"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polyester_Resin -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polyester_Resin">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermosets"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polymer -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polymer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Material_Core"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polystirene -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polystirene">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermoplastics"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Stainless -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Stainless">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Alloy"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Tool_High_Alloy"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Steel -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Steel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Ferrous"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermoplastics -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermoplastics">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polymer"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermosets -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermosets">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polymer"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Tool_High_Alloy -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Tool_High_Alloy">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Alloy"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Tool_Low_Alloy -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Tool_Low_Alloy">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Carbon"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Urea_Formaldehyde -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Urea_Formaldehyde">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermosets"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#White_Iron -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#White_Iron">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Cast_Irons"/>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#P2 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#P2">
        <rdf:type rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Strenght_Low_Alloy"/>
        <rdf:type rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Carbon"/>
        <Material_Core:hasDensityValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7.86</Material_Core:hasDensityValue>
        <Material_Core:hasHardnessValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">61</Material_Core:hasHardnessValue>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#P20 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#P20">
        <rdf:type rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Strenght_Low_Alloy"/>
        <rdf:type rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Carbon"/>
        <Material_Core:hasApplication>P20 tool steels are used for low temperature applications that include injection molds and die casting dies.</Material_Core:hasApplication>
        <Material_Core:hasDensityValue rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7.85</Material_Core:hasDensityValue>
        <Material_Core:hasHardnessValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</Material_Core:hasHardnessValue>
        <Material_Core:hasTensileStrengthValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1000</Material_Core:hasTensileStrengthValue>
    </owl:NamedIndividual>
    


