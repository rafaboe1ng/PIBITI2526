        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Natural"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polymer"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Natural -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Natural">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Material_Core"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polymer"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Nonferrous -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Nonferrous">
