    <minCutRadius rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.5</minCutRadius>
    <rdfs:comment xml:lang="en">Fiber laser cutter for aerospace sheet metal. 4kW rated power, handles aluminum and titanium alloys up to 30mm. Minimum corner radius limited by 0.3mm kerf.</rdfs:comment>
    <rdfs:label xml:lang="en">LaserCutter_01</rdfs:label>
  </rdf:Description>
