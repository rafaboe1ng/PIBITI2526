    <rdfs:label xml:lang="en">recommendedProcess</rdfs:label>
    <rdfs:comment xml:lang="en">System output: a process the feature requires, inferred from its viable machine. Correct process, shown independently of the users choice.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#FormingStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
