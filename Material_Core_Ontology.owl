    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Plain_High_Carbon -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Plain_High_Carbon">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Carbon"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Plain_Low_Carbon -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Plain_Low_Carbon">
