    <!-- http://www.semanticweb.org/rafab/ontologies/Material_Core_Ontology#Metal -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/Material_Core_Ontology#Metal"/>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Aluminum -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Aluminum">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/Material_Core_Ontology#Metal"/>
        <rdfs:comment xml:lang="en">Aluminum alloys. Subclass of mc:Metal added in PIBITI2526 namespace because Material_Core_Ontology does not define a non-ferrous metal hierarchy.</rdfs:comment>
        <rdfs:label xml:lang="en">Aluminum</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Attachment_Flange -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Attachment_Flange">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Bending"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Attachment_Hole -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Attachment_Hole">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Hole"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Tooling_Hole"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Boss -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Boss">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Drawing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Chamfer -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Chamfer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Chamfering"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Corner -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Corner">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Cutting"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Deformed_Flange -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Deformed_Flange">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Drawing"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Hydroforming"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#DrillPress -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#DrillPress">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Machine"/>
        <rdfs:comment xml:lang="pt">Furadeira/CNC de furação. Opera por remoção de material rotacional.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Hole -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Hole">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Drilling"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Laser_Cutting"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Punching"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#HydroformPress -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#HydroformPress">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Machine"/>
        <rdfs:comment xml:lang="pt">Prensa hidroformadora. Conforma flanges complexas por pressão hidráulica.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#LaserCutter -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#LaserCutter">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Machine"/>
        <rdfs:comment xml:lang="en">Sheet metal laser cutting machine. Uses a focused laser beam to cut profiles, corners, holes, and slots. Constrained by minimum achievable cut radius (kerf-dependent) and maximum sheet thickness (power-dependent).</rdfs:comment>
        <rdfs:label xml:lang="en">Laser_Cutter</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#PressBreake -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#PressBreake">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Machine"/>
        <rdfs:comment xml:lang="pt">Prensa dobradeira. Executa dobramento de flanges por força sobre matriz.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature">
        <rdfs:comment xml:lang="en">A geometric/topological characteristic of a Sheet_Metal_Part (hole, flange, web, corner, boss, chamfer, slot, thread). A Product_Feature is NOT itself a Product - it is a dependent characteristic of one. Linked to its host Sheet_Metal_Part via the isFeatureOf object property.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#PunchPress -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#PunchPress">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Machine"/>
        <rdfs:comment xml:lang="pt">Máquina de puncionamento. Opera sobre chapa plana, executa furos e recortes por impacto de punção.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Sheet_Metal_Part">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Product"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Slot -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Slot">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Laser_Cutting"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Punching"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Waterjet_Cutting"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Stiffening_Flange -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Stiffening_Flange">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Flange"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Bending"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Thread -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Thread">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#requiresProcess"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Tapping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Tooling_Hole -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Tooling_Hole">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Hole"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Web -->

    <owl:Class rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Web">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Product_Feature"/>
    </owl:Class>
    


