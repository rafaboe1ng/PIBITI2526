    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Ageing_Process -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Ageing_Process">
        <rdf:type rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Ageing"/>
        <rdfs:label xml:lang="en">Ageing_Process</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Aluminum_7075 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Aluminum_7075">
        <rdf:type rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Aluminum"/>
        <hasMinBendRadiusCoefficient rdf:datatype="http://www.w3.org/2001/XMLSchema#double">2.0</hasMinBendRadiusCoefficient>
        <rdfs:comment xml:lang="en">Aluminum alloy 7075 (Al-Zn-Mg-Cu). High-strength aerospace alloy. hasMinBendRadiusCoefficient=2.0 is ESTIMATED for O-temper (annealed). Replace with catalog value when temper is known.</rdfs:comment>
        <rdfs:label xml:lang="en">Aluminum_7075</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Annealing_Process -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Annealing_Process">
        <rdf:type rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Annealing"/>
        <rdfs:label xml:lang="en">Annealing_Process</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Anodizing_Process -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Anodizing_Process">
        <rdf:type rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Anodizing"/>
        <rdfs:label xml:lang="en">Anodizing_Process</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Bending_Process -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Bending_Process">
        <rdf:type rdf:resource="http://www.semanticweb.org/rafab/ontologies/manufacturing_core#Bending"/>
        <precedesProcess rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Deburring_Process"/>
        <precedesProcess rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Finishing_Process"/>
        <precedesProcess rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Grinding_Process"/>
        <rdfs:label xml:lang="en">Bending_Process</rdfs:label>
