    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Plain_Medium_Carbon -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Plain_Medium_Carbon">
