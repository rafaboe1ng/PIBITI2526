    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Infers HydroformPress capability for Deformed_Flange with a curved or compound profile. These flanges require material to stretch or shrink across the bend line and cannot be produced with a standard press brake die.</rdfs:comment>
        <rdfs:label>Deformed_Flange_Curved</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#Deformed_Flange"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#f"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasFlangeProfile"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#f"/>
                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#profile"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
                                        <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#stringEqualIgnoreCase"/>
                                        <swrl:arguments>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#profile"/>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>Curved</rdf:first>
                                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </swrl:arguments>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasWidth"/>
                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#f"/>
                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#w"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#hasLength"/>
                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#f"/>
                                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#l"/>
                                                    </rdf:Description>
                                                </rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                        <rdf:first>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                                                <swrl:classPredicate rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#HydroformPress"/>
                                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#m"/>
                                                            </rdf:Description>
                                                        </rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                <rdf:first>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#maxBedSizeX"/>
                                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#m"/>
                                                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/rafab/ontologies/PIBITI2526#bx"/>
                                                                    </rdf:Description>
                                                                </rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
