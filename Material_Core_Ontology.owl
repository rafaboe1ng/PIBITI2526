    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasConversion -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasConversion"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasPropertyName -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasPropertyName"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasSharing -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasSharing"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasTranslation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasTranslation"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasTypeOfProperty -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasTypeOfProperty"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasUnitSystem -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasUnitSystem"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasApplication -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasApplication"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasCavityTemp -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasCavityTemp"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasChemResistValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasChemResistValue"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasCost -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasCost"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasDensityValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasDensityValue"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasHDTValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasHDTValue"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasHardnessValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasHardnessValue"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasMeltingTemp -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasMeltingTemp"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasShrinkageRateValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasShrinkageRateValue">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasTensileModulusValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasTensileModulusValue"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasTensileStrengthValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasTensileStrengthValue"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasThermalConducValue -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#hasThermalConducValue"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#ABS -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#ABS">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermoplastics"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#BioDegradeable -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#BioDegradeable">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polymer"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermoplastics"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermosets"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Cast_Irons -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Cast_Irons">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Ferrous"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Steel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Ceramic -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Ceramic">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Material_Core"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Metal"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Natural"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Polymer"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Ductile_Iron -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Ductile_Iron">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Cast_Irons"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Epoxy_Resin -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Epoxy_Resin">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermosets"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Ferrous -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Ferrous">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Metal"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Nonferrous"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Gray_Iron -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Gray_Iron">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Cast_Irons"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Heat_Treatable -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Heat_Treatable">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Medium_Carbon"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Alloy -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Alloy">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Steel"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Alloy"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Carbon -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Carbon">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Alloy"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Strenght_Low_Alloy -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#High_Strenght_Low_Alloy">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Carbon"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Alloy -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Alloy">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Steel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Carbon -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Carbon">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Alloy"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Malleable_Iron -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Malleable_Iron">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Cast_Irons"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Material_Core -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Material_Core"/>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Medium_Carbon -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Medium_Carbon">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Low_Alloy"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Melamine_Formaldehyde -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Melamine_Formaldehyde">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Thermosets"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Metal -->

    <owl:Class rdf:about="http://www.semanticweb.org/athon.leite/ontologies/2015/10/Material_Core#Metal">
